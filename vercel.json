{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "app.kimchi.so" }],
      "destination": "https://kimchi.so/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/company-jobs-scan",
      "schedule": "0 6 * * 0"
    },
    {
      "path": "/api/cron/topechelon-sync",
      "schedule": "0 7 * * 0"
    },
    {
      "path": "/api/cron/airtable-coaches-sync",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/recommended-jobs-snapshot",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/job-search-emails",
      "schedule": "30 8 * * *"
    },
    {
      "path": "/api/cron/booking-reminders",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/execthread-sync",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/live-sessions",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/email-agent-sync",
      "schedule": "*/15 * * * *"
    }
  ]
}
