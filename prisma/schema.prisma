generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatarUrl String?
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stripeCustomerId String? @unique

  profile          Profile?
  jobs             Job[]
  subscription     Subscription?
  tailoredResumes  TailoredResume[]
  coachProfile     CoachProfile?
  aiUsageLogs      AiUsageLog[]
}

enum UserRole {
  USER
  COACH
  RECRUITER
  ADMIN
}

model Subscription {
  id                     String             @id @default(cuid())
  userId                 String             @unique
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  stripeSubscriptionId   String             @unique
  stripePriceId          String
  stripeCurrentPeriodEnd DateTime
  status                 SubscriptionStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  UNPAID
  TRIALING
  INCOMPLETE
  INCOMPLETE_EXPIRED
  PAUSED
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  resumeUrl   String?
  resumeText  String?
  parsedData  Json?
  linkedinUrl String?
  headline    String?
  summary     String?
  targetRoles String[]
  targetSalary Int?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Job {
  id      String   @id @default(cuid())
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  url          String?
  company      String
  role         String
  stage        JobStage @default(SAVED)
  notes        String?

  resumeUrl    String?
  coverLetter  String?
  fitAnalysis  String?

  appliedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tailoredResume TailoredResume?
}

model TailoredResume {
  id        String   @id @default(cuid())
  jobId     String   @unique
  userId    String
  sections  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CoachProfile {
  id             String      @id @default(cuid())
  userId         String?     @unique
  user           User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  airtableId     String?     @unique

  displayName    String
  email          String?     @unique
  headline       String?
  bio            String?
  currentRole    String?
  currentCompany String?
  location       String?
  linkedinUrl    String?
  lelandUrl      String?
  photoUrl       String?

  firms          String[]
  schools        String[]
  specialties    String[]
  industries     String[]

  hourlyRate     Int?
  category       String?
  featured       Boolean     @default(false)
  status         CoachStatus @default(ACTIVE)

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

enum CoachStatus {
  ACTIVE
  PENDING
  INACTIVE
}

enum JobStage {
  SAVED
  APPLYING
  APPLIED
  SCREENING
  INTERVIEWING
  OFFER
  REJECTED
  WITHDRAWN
}

enum AiFeature {
  COVER_LETTER
  FIT_ANALYSIS
  RESUME_BULLETS
  RESUME_PARSE
  JOB_PARSE
  CHAT
  RESUME_TAILOR
}

model AiUsageLog {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  feature   AiFeature
  model     String
  tokensIn  Int        @default(0)
  tokensOut Int        @default(0)
  costUsd   Float      @default(0)
  createdAt DateTime   @default(now())

  @@index([userId])
  @@index([createdAt])
}
