generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatarUrl String?
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stripeCustomerId String? @unique

  profile          Profile?
  jobs             Job[]
  trackedCompanies TrackedCompany[]
  subscription     Subscription?
  tailoredResumes  TailoredResume[]
  coachProfile     CoachProfile?
  aiUsageLogs      AiUsageLog[]
  monthlyUsage     MonthlyUsage[]
  assets           UserAsset[]
}

enum UserRole {
  USER
  COACH
  RECRUITER
  ADMIN
}

model Subscription {
  id                     String             @id @default(cuid())
  userId                 String             @unique
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  stripeSubscriptionId   String             @unique
  stripePriceId          String
  stripeCurrentPeriodEnd DateTime
  status                 SubscriptionStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  UNPAID
  TRIALING
  INCOMPLETE
  INCOMPLETE_EXPIRED
  PAUSED
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  resumeUrl   String?
  resumeText  String?
  parsedData  Json?
  linkedinUrl String?
  headline    String?
  summary     String?
  targetRoles      String[]
  targetSalary     String?
  employmentStatus String?
  currentSalary    String?
  priorities       String[]
  careerMotivation String?
  jobTimeline      String?
  attribution      String?

  readbackData       Json?
  readbackUpdatedAt  DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum AssetType {
  RESUME
  COVER_LETTER
  JOB_SEARCH_STRATEGY
  OTHER
}

model UserAsset {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      AssetType
  name      String
  url       String
  isPrimary Boolean   @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
}

model Job {
  id      String   @id @default(cuid())
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  url          String?
  company      String
  role         String
  stage        JobStage @default(SAVED)
  notes        String?

  // Parsed from job posting
  location     String?
  salary       String?
  description  String?
  requirements String[]

  // AI match analysis (persisted)
  fitScore     Float?
  matchData    Json?
  tags         String[]

  userNotes          String?
  companyLinkedinUrl String?

  resumeUrl    String?
  coverLetter  String?
  fitAnalysis  String?

  appliedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tailoredResume TailoredResume?
}

model TailoredResume {
  id        String   @id @default(cuid())
  jobId     String   @unique
  userId    String
  sections  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CoachProfile {
  id             String      @id @default(cuid())
  userId         String?     @unique
  user           User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  airtableId     String?     @unique

  displayName    String
  email          String?     @unique
  headline       String?
  bio            String?
  currentRole    String?
  currentCompany String?
  location       String?
  linkedinUrl    String?
  lelandUrl      String?
  photoUrl       String?

  firms          String[]
  schools        String[]
  specialties    String[]
  industries     String[]

  hourlyRate     Int?
  category       String?
  featured       Boolean     @default(false)
  status         CoachStatus @default(ACTIVE)

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

enum CoachStatus {
  ACTIVE
  PENDING
  INACTIVE
}

enum JobStage {
  SAVED
  APPLYING
  APPLIED
  SCREENING
  INTERVIEWING
  OFFER
  REJECTED
  WITHDRAWN
}

enum AiFeature {
  COVER_LETTER
  FIT_ANALYSIS
  RESUME_BULLETS
  RESUME_PARSE
  JOB_PARSE
  CHAT
  RESUME_TAILOR
}

model TrackedCompany {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name              String
  website           String?
  notes             String?
  type              String?
  hqLocation        String?
  priority          String?
  cultureMission    String?
  candidateEdge     String?
  targetRoles       String?
  careersUrl           String?
  jobsCache            Json?
  lastJobsFetchedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model CompanyIntel {
  id                  String    @id @default(cuid())
  name                String    @unique
  enrichmentCache     Json?
  enrichmentFetchedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AiUsageLog {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  feature   AiFeature
  model     String
  tokensIn  Int        @default(0)
  tokensOut Int        @default(0)
  costUsd   Float      @default(0)
  createdAt DateTime   @default(now())

  @@index([userId])
  @@index([createdAt])
}

model MonthlyUsage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month     String
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([userId, month])
  @@index([userId])
}

model PromptConfig {
  id             String   @id @default(cuid())
  key            String   @unique
  label          String
  description    String
  category       String   @default("General")
  content        String
  defaultContent String
  updatedAt      DateTime @updatedAt
  updatedBy      String?
}

model MarketSignals {
  id          String   @id @default(cuid())
  data        Json
  generatedAt DateTime @default(now())
  generatedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
