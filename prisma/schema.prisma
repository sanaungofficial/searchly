generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatarUrl String?
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stripeCustomerId String? @unique

  referralCode         String?   @unique
  referredByUserId     String?
  referredBy           User?     @relation("UserReferrals", fields: [referredByUserId], references: [id], onDelete: SetNull)
  referrals            User[]    @relation("UserReferrals")
  onboardingCompletedAt DateTime?

  profile          Profile?
  jobs             Job[]
  trackedCompanies TrackedCompany[]
  subscription     Subscription?
  tailoredResumes  TailoredResume[]
  coachProfile     CoachProfile?
  aiUsageLogs      AiUsageLog[]
  monthlyUsage     MonthlyUsage[]
  dailyFeatureUsage DailyFeatureUsage[]
  featureCreditBonus FeatureCreditBonus[]
  assets           UserAsset[]
  referralsSent    ReferralEvent[] @relation("ReferrerEvents")
  referralReceived ReferralEvent?  @relation("RefereeEvent")
  linkedInShareSubmissions LinkedInShareSubmission[]
  proTrialGrants   ProTrialGrant[]
  recommendedSnapshots RecommendedJobSnapshot[]
  digestSettings       UserDigestSettings?
  coachReviews         CoachReview[]
  coachFollows         CoachFollow[]
  coachAssignments     CoachClientAssignment[] @relation("ClientCoachAssignments")
  coachAssignmentsMade CoachClientAssignment[] @relation("CoachAssignmentAdmin")
  coachSharedDocumentsReceived CoachSharedDocument[] @relation("CoachSharedDocsClient")
  coachSharedDocumentsUploaded CoachSharedDocument[] @relation("CoachSharedDocsUploader")
  coachClientSessionNotesReceived CoachClientSessionNote[] @relation("CoachSessionNotesClient")
  coachClientSessionNotesAuthored CoachClientSessionNote[] @relation("CoachSessionNotesAuthor")
  coachBookings        CoachBooking[]       @relation("CoachBookingGuest")
  coachBookingComms    CoachBookingCommunication[] @relation("CoachBookingComms")
  coachPurchases       CoachPurchase[]      @relation("CoachPurchaseBuyer")
  liveSessionRegistrations LiveSessionRegistration[]
  liveSessionEvents      LiveSessionEvent[]
  emailGrant           UserEmailGrant?
  jobAgentSettings     UserJobAgentSettings?
  jobActivityLogs      JobActivityLog[]
  inboxContacts        InboxContact[]
  inboxActivities      InboxActivity[]
  assistantThreads     AssistantThread[]
  networkJobRequests   NetworkJobRequest[]
  applicationQaEntries ApplicationQaEntry[]
  importRunsAsClient   ImportRun[] @relation("ClientImportRuns")
  importRunsPerformed  ImportRun[] @relation("ImportedByImportRuns")

  @@index([referredByUserId])
}

enum UserRole {
  USER
  COACH
  ADMIN
}

model Subscription {
  id                     String             @id @default(cuid())
  userId                 String             @unique
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  stripeSubscriptionId   String             @unique
  stripePriceId          String
  stripeCurrentPeriodEnd DateTime
  status                 SubscriptionStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  UNPAID
  TRIALING
  INCOMPLETE
  INCOMPLETE_EXPIRED
  PAUSED
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  resumeUrl   String?
  resumeText  String?
  parsedData  Json?
  linkedinUrl String?
  headline    String?
  summary     String?
  targetRoles      String[]
  /** Title patterns to boost highest in job feeds — reorder only, not hidden. */
  prioritizedRoles String[] @default([])
  /** Hirebase job category buckets to boost (e.g. Operations Jobs). */
  prioritizedCategories String[] @default([])
  /** Title patterns to sort lower in job feeds — reorder only, not hidden. */
  deprioritizedRoles String[] @default([])
  /** Hirebase job category buckets to deprioritize (e.g. Sales Jobs). */
  deprioritizedCategories String[] @default([])
  targetSalary     String?
  employmentStatus String?
  currentSalary    String?
  priorities       String[]
  careerMotivation String?
  jobTimeline      String?
  attribution      String?

  readbackData       Json?
  readbackUpdatedAt  DateTime?

  linkedInDraft              Json?
  linkedInDraftUpdatedAt     DateTime?
  linkedInDraftSourceAssetId String?
  linkedInDraftAnalysis      Json?
  linkedInDraftAnalysisUpdatedAt DateTime?

  roleAnalyses    Json?
  skillGoals      Json?
  upskillProgress Json?
  targetRoleSettings Json?

  targetMarket           String?
  relocationOpenness     String?
  workAuthorization      String?
  securityClearance      String?
  searchDuration         String?
  positioningStatement   String?  @db.Text

  strategyData             Json?
  strategyUpdatedAt        DateTime?
  strategySourceSnapshot   Json?
  strategyIntakeNotes      String?  @db.Text
  strategyHistory          Json?
  strategyGenerationStatus      String?
  strategyGenerationStartedAt   DateTime?
  strategyGenerationCompletedAt DateTime?
  strategyGenerationError       String?  @db.Text

  profileSuggestionsData       Json?
  profileSuggestionsUpdatedAt  DateTime?

  companyRecommendationsCache       Json?
  companyRecommendationsUpdatedAt   DateTime?

  dashboardGoals Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum AssetType {
  RESUME
  COVER_LETTER
  JOB_SEARCH_STRATEGY
  PORTFOLIO
  WRITING_SAMPLE
  REFERENCE
  CERTIFICATION
  TRANSCRIPT
  OTHER
}

model UserAsset {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      AssetType
  name      String
  url       String
  isPrimary Boolean   @default(false)

  resumeText         String?
  parsedData         Json?
  analysisData       Json?
  analysisUpdatedAt  DateTime?
  targetJobTitle     String?
  parseStatus        String?
  parseStartedAt     DateTime?
  parseCompletedAt   DateTime?
  parseError         String?  @db.Text

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
}

model Job {
  id      String   @id @default(cuid())
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  url          String?
  company      String
  role         String
  stage        JobStage @default(SAVED)
  notes        String?

  userNotes          String?
  companyLinkedinUrl String?

  resumeUrl    String?
  coverLetter  String?
  fitAnalysis  String?

  appliedAt    DateTime?
  pipelineFollowUpSentAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tailoredResume TailoredResume?
  activityLogs   JobActivityLog[]
  inboxActivities InboxActivity[]
  inboxContacts  JobInboxContact[]
}

model TailoredResume {
  id        String   @id @default(cuid())
  jobId     String   @unique
  userId    String
  sections  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CoachProfile {
  id             String      @id @default(cuid())
  userId         String?     @unique
  user           User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  airtableId     String?     @unique

  displayName    String
  email          String?     @unique
  headline       String?
  bio            String?
  currentRole    String?
  currentCompany String?
  location       String?
  linkedinUrl    String?
  lelandUrl      String?
  photoUrl       String?

  firms          String[]
  schools        String[]
  specialties    String[]
  industries     String[]

  hourlyRate     Int?
  category       String?
  featured       Boolean     @default(false)
  isInternal          Boolean     @default(false)
  requiresAssignment  Boolean     @default(false)
  status              CoachStatus @default(ACTIVE)

  /// Pricing & offerings (Leland-style coach pricing page)
  introOfferType              CoachIntroOfferType @default(FREE_INTRO)
  introDurationMinutes        Int                 @default(15)
  trialSessionDurationMinutes Int?
  salesAssistedLeadsEnabled   Boolean             @default(false)
  partnerProgramEnabled       Boolean             @default(false)
  packagesSyncToHourly        Boolean             @default(true)

  slug                  String?  @unique
  calLink               String?
  nylasGrantId          String?  @unique
  nylasGrantEmail       String?
  nylasGrantStatus      String?  @default("active") // active | expired
  nylasEmailSyncEnabled Boolean  @default(false)
  nylasSchedulerConfigId String? @unique
  nylasIntroSchedulerConfigId String? @unique
  nylasSchedulerSlug    String?
  nylasIntroSchedulerSlug String?
  nylasSchedulerCalendarIds Json?
  nylasConferenceProvider String? // google_meet | microsoft_teams
  schedulerDurationMinutes Int   @default(30)
  schedulerTimezone        String? @default("America/New_York")
  schedulerOpenHourStart   String? @default("09:00")
  schedulerOpenHourEnd     String? @default("17:00")
  schedulerOpenDays        Int[]   @default([1, 2, 3, 4, 5])
  schedulerWeeklyHours       Json?
  schedulerBufferMinutes     Int     @default(0)
  schedulerMinBookingNoticeMinutes Int @default(1440)
  schedulerCapacityHoursPerWeek Int?
  schedulerAvailabilityNotes String?
  schedulerBlackoutDates     Json?
  clientSpecializations String[] @default([])
  experienceLevel       String?
  clientTier            String?
  industryYears         Int?
  isProfessionalCoach   Boolean  @default(false)
  whyCoach              String?
  aboutMe               String?
  clientWins            String[] @default([])

  vouches        CoachVouch[]
  reviews        CoachReview[]
  followers      CoachFollow[]
  clientAssignments CoachClientAssignment[]
  sharedDocuments   CoachSharedDocument[]
  clientSessionNotes CoachClientSessionNote[]
  bookings       CoachBooking[]
  communications CoachBookingCommunication[]
  liveSessions   LiveSession[]
  liveSessionCoHosts LiveSessionCoHost[]
  pricingPackages CoachPricingPackage[]
  bulkDiscounts   CoachBulkDiscount[]
  purchases       CoachPurchase[]

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

enum CoachIntroOfferType {
  FREE_INTRO
  TRIAL_SESSION
}

model CoachPricingPackage {
  id             String       @id @default(cuid())
  coachProfileId String
  coachProfile   CoachProfile @relation(fields: [coachProfileId], references: [id], onDelete: Cascade)
  title          String?
  description    String?
  hours          Int
  hoursMax       Int?
  label          String?
  priceCents     Int?
  syncedToHourly Boolean      @default(true)
  isPublic       Boolean      @default(true)
  enabled        Boolean      @default(true)
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  purchases      CoachPurchase[]

  @@index([coachProfileId])
}

enum CoachPurchaseStatus {
  PENDING
  PAID
  REFUNDED
  PARTIALLY_REFUNDED
  FAILED
  CANCELED
}

enum CoachPurchaseLeadSource {
  MARKETPLACE
  SALES_ASSISTED
  COACH_REFERRAL
  DIRECT_LINK
}

model CoachPurchase {
  id               String                  @id @default(cuid())
  coachProfileId   String
  coachProfile     CoachProfile            @relation(fields: [coachProfileId], references: [id], onDelete: Cascade)
  buyerUserId      String?
  buyer            User?                   @relation("CoachPurchaseBuyer", fields: [buyerUserId], references: [id], onDelete: SetNull)
  packageId        String?
  package          CoachPricingPackage?    @relation(fields: [packageId], references: [id], onDelete: SetNull)

  /// Snapshot at checkout time
  packageTitle     String
  packageHours     Int
  packageHoursMax  Int?

  amountCents      Int
  platformFeeCents Int
  stripeFeeCents   Int                     @default(0)
  coachPayoutCents Int
  currency         String                  @default("usd")

  hoursGranted     Int
  hoursRemaining   Int

  status           CoachPurchaseStatus     @default(PENDING)
  leadSource       CoachPurchaseLeadSource @default(MARKETPLACE)
  salesAssisted    Boolean                 @default(false)

  buyerEmail       String?
  buyerName        String?

  stripeCheckoutSessionId String?          @unique
  stripePaymentIntentId   String?          @unique

  paidAt           DateTime?
  refundedAt       DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([coachProfileId])
  @@index([buyerUserId])
  @@index([status])
  @@index([createdAt])
}

model CoachBulkDiscount {
  id              String       @id @default(cuid())
  coachProfileId  String
  coachProfile    CoachProfile @relation(fields: [coachProfileId], references: [id], onDelete: Cascade)
  minHours        Int
  discountPercent Int
  enabled         Boolean      @default(true)
  sortOrder       Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([coachProfileId, minHours])
  @@index([coachProfileId])
}

enum CoachBookingStatus {
  CONFIRMED
  PENDING
  CANCELLED
  RESCHEDULED
}

model CoachBooking {
  id              String             @id @default(cuid())
  coachProfileId  String
  coachProfile    CoachProfile       @relation(fields: [coachProfileId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?              @relation("CoachBookingGuest", fields: [userId], references: [id], onDelete: SetNull)

  nylasBookingId  String?            @unique
  nylasBookingRef String?            @unique
  nylasConfigId   String?
  nylasEventId    String?
  guestName       String?
  guestEmail      String?
  title           String?
  location        String?
  startAt         DateTime
  endAt           DateTime
  status          CoachBookingStatus @default(CONFIRMED)
  rawPayload      Json?
  communications  CoachBookingCommunication[]
  sessionNotes    CoachClientSessionNote[]

  reminder24hSentAt DateTime?
  reminder1hSentAt  DateTime?

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([coachProfileId])
  @@index([userId])
  @@index([guestEmail])
  @@index([startAt])
}

enum CoachBookingCommType {
  GUEST_CONFIRMATION
  COACH_NOTIFICATION
  CANCELLATION
  SESSION_BOOKED
  SESSION_RESCHEDULED
  REMINDER_24H
  REMINDER_1H
  GUEST_RESCHEDULED
}

enum CoachBookingCommAudience {
  GUEST
  COACH
}

/// Booking-related emails and session lifecycle events (Option A communications).
model CoachBookingCommunication {
  id             String                   @id @default(cuid())
  bookingId      String?
  booking        CoachBooking?            @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  coachProfileId String
  coachProfile   CoachProfile             @relation(fields: [coachProfileId], references: [id], onDelete: Cascade)
  clientUserId   String?
  clientUser     User?                    @relation("CoachBookingComms", fields: [clientUserId], references: [id], onDelete: SetNull)
  type           CoachBookingCommType
  audience       CoachBookingCommAudience
  recipientEmail String
  subject        String
  bodyPreview    String?
  createdAt      DateTime                 @default(now())

  @@index([coachProfileId, createdAt])
  @@index([clientUserId, createdAt])
  @@index([bookingId])
}

enum LiveSessionFormat {
  INTERACTIVE
  BROADCAST
}

enum LiveSessionStatus {
  DRAFT
  PENDING_APPROVAL
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

model LiveSession {
  id               String            @id @default(cuid())
  legacyNumericId  Int?              @unique

  title            String
  description      String
  category         String            @default("General")

  coachProfileId   String?
  coachProfile     CoachProfile?     @relation(fields: [coachProfileId], references: [id], onDelete: SetNull)

  hostName         String
  hostInitials     String?
  hostRole         String?
  hostRating       Float?
  hostReviewCount  Int               @default(0)

  scheduledStart   DateTime
  scheduledEnd     DateTime
  timezone         String            @default("America/New_York")
  status           LiveSessionStatus @default(DRAFT)
  format           LiveSessionFormat @default(INTERACTIVE)

  coverImageUrl    String?
  replayEnabled    Boolean           @default(false)
  rejectionReason  String?
  submittedForApprovalAt DateTime?
  approvedAt       DateTime?

  isFeaturedWeekly Boolean           @default(false)
  bgColor          String            @default("#1A3A2F")
  accentColor      String            @default("#E8D5A3")

  hmsRoomId        String?

  wentLiveAt       DateTime?
  endedAt          DateTime?
  liveNowEmailSentAt DateTime?
  postSessionEmailSentAt DateTime?
  followNotifySentAt DateTime?
  followerPostSessionSentAt DateTime?

  peakViewers        Int               @default(0)
  totalUniqueJoins   Int               @default(0)
  recordingUrl       String?
  recordingReadyAt   DateTime?
  hmsRecordingId     String?
  hmsLiveStreamId    String?
  hlsPlaybackUrl     String?

  registrations    LiveSessionRegistration[]
  events           LiveSessionEvent[]
  coHosts          LiveSessionCoHost[]

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([status])
  @@index([scheduledStart])
  @@index([coachProfileId])
}

model LiveSessionCoHost {
  id             String        @id @default(cuid())
  liveSessionId  String
  liveSession    LiveSession   @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  coachProfileId String?
  coachProfile   CoachProfile? @relation(fields: [coachProfileId], references: [id], onDelete: SetNull)
  displayName    String
  email          String?
  sortOrder      Int           @default(0)
  createdAt      DateTime      @default(now())

  @@index([liveSessionId])
  @@index([coachProfileId])
}

enum LiveSessionEventType {
  REGISTERED
  REMINDER_SENT
  LIVE_NOW_SENT
  FOLLOWER_NOTIFIED
  JOINED
  LEFT
  RECORDING_STARTED
  RECORDING_READY
  POST_SESSION_SENT
  SESSION_STARTED
  SESSION_ENDED
  PEER_REMOVED
}

model LiveSessionEvent {
  id            String               @id @default(cuid())
  liveSessionId String
  liveSession   LiveSession          @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  type          LiveSessionEventType
  metadata      Json?
  createdAt     DateTime             @default(now())

  @@index([liveSessionId, type])
  @@index([liveSessionId, createdAt])
  @@index([userId])
}

model LiveSessionRegistration {
  id            String      @id @default(cuid())
  liveSessionId String
  liveSession   LiveSession @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  joinedAt      DateTime?
  reminderSentAt DateTime?
  reminder24hSentAt DateTime?
  reminder1hSentAt DateTime?
  createdAt     DateTime    @default(now())

  @@unique([liveSessionId, userId])
  @@index([userId])
}

model CoachVouch {
  id             String       @id @default(cuid())
  coachProfileId String
  coachProfile   CoachProfile @relation(fields: [coachProfileId], references: [id], onDelete: Cascade)

  authorName     String
  authorEmail    String?
  relationship   String?
  message        String

  createdAt      DateTime     @default(now())

  @@index([coachProfileId])
}

model CoachReview {
  id             String       @id @default(cuid())
  coachProfileId String
  coachProfile   CoachProfile @relation(fields: [coachProfileId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  authorName     String
  coachedFor     String?
  rating         Float
  knowledge      Int
  value          Int
  responsiveness Int
  supportiveness Int
  message        String

  createdAt      DateTime @default(now())

  @@unique([coachProfileId, userId])
  @@index([coachProfileId])
}

model CoachFollow {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  coachProfileId String
  coachProfile   CoachProfile @relation(fields: [coachProfileId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())

  @@unique([userId, coachProfileId])
  @@index([coachProfileId])
  @@index([userId])
}

/// Admin-assigned coach for a client (internal Kimchi coaches, not marketplace).
model CoachClientAssignment {
  id               String       @id @default(cuid())
  userId           String
  user             User         @relation("ClientCoachAssignments", fields: [userId], references: [id], onDelete: Cascade)
  coachProfileId   String
  coachProfile     CoachProfile @relation(fields: [coachProfileId], references: [id], onDelete: Cascade)
  assignedByUserId String?
  assignedBy       User?        @relation("CoachAssignmentAdmin", fields: [assignedByUserId], references: [id], onDelete: SetNull)
  notes            String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, coachProfileId])
  @@index([userId])
  @@index([coachProfileId])
}

/// Coach-shared file for a client (career strategy, resources, etc.) or public profile resource.
model CoachSharedDocument {
  id               String       @id @default(cuid())
  coachProfileId   String
  coachProfile     CoachProfile @relation(fields: [coachProfileId], references: [id], onDelete: Cascade)
  clientUserId     String?
  clientUser       User?        @relation("CoachSharedDocsClient", fields: [clientUserId], references: [id], onDelete: Cascade)
  uploadedByUserId String
  uploadedBy       User         @relation("CoachSharedDocsUploader", fields: [uploadedByUserId], references: [id], onDelete: Cascade)

  type        AssetType
  name        String
  storagePath String
  mimeType    String?
  notes       String?
  isPublic    Boolean      @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientUserId])
  @@index([coachProfileId, clientUserId])
  @@index([coachProfileId, isPublic])
}

/// Text-only session notes and homework from expert to client (no file required).
model CoachClientSessionNote {
  id              String        @id @default(cuid())
  coachProfileId  String
  coachProfile    CoachProfile  @relation(fields: [coachProfileId], references: [id], onDelete: Cascade)
  clientUserId    String
  clientUser      User          @relation("CoachSessionNotesClient", fields: [clientUserId], references: [id], onDelete: Cascade)
  createdByUserId String
  createdBy       User          @relation("CoachSessionNotesAuthor", fields: [createdByUserId], references: [id], onDelete: Cascade)
  coachBookingId  String?
  coachBooking    CoachBooking? @relation(fields: [coachBookingId], references: [id], onDelete: SetNull)
  sessionNotes    String?
  homework        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([clientUserId])
  @@index([coachProfileId, clientUserId])
}

enum CoachStatus {
  ACTIVE
  PENDING
  INACTIVE
}

enum JobStage {
  SAVED
  APPLYING
  APPLIED
  SCREENING
  INTERVIEWING
  OFFER
  REJECTED
  WITHDRAWN
}

enum AiFeature {
  COVER_LETTER
  FIT_ANALYSIS
  RESUME_BULLETS
  RESUME_PARSE
  JOB_PARSE
  CHAT
  RESUME_TAILOR
  EMAIL_JOB_SIGNAL
}

enum ExternalApiProvider {
  HIREBASE
  APIFY
  TOPECHELON
  EXECTHREAD
}

enum NetworkJobSource {
  TOPECHELON
  EXECTHREAD
}

model CompanyIntel {
  id                   String    @id @default(cuid())
  name                 String
  slug                 String    @unique
  website              String?
  careersUrl           String?
  jobsCache            Json?
  lastJobsFetchedAt    DateTime?
  enrichmentCache      Json?
  enrichmentFetchedAt  DateTime?

  trackedCompanies TrackedCompany[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TrackedCompany {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyIntelId       String?
  companyIntel         CompanyIntel? @relation(fields: [companyIntelId], references: [id], onDelete: SetNull)

  name              String
  website           String?
  notes             String?
  type              String?
  hqLocation        String?
  priority          String?
  cultureMission    String?
  candidateEdge     String?
  targetRoles       String?
  careersUrl           String?
  jobsCache            Json?
  lastJobsFetchedAt    DateTime?
  enrichmentCache      Json?
  enrichmentFetchedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([companyIntelId])
}

model AiUsageLog {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  feature   AiFeature
  model     String
  tokensIn  Int        @default(0)
  tokensOut Int        @default(0)
  costUsd   Float      @default(0)
  createdAt DateTime   @default(now())

  @@index([userId])
  @@index([createdAt])
}

model ExternalApiUsageLog {
  id        String              @id @default(cuid())
  provider  ExternalApiProvider
  operation String
  userId    String?
  units     Int                 @default(1)
  costUsd   Float               @default(0)
  meta      Json?
  createdAt DateTime            @default(now())

  @@index([provider])
  @@index([createdAt])
  @@index([userId])
}

model MonthlyUsage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month     String
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([userId, month])
  @@index([userId])
}

model PromptConfig {
  id             String   @id @default(cuid())
  key            String   @unique
  label          String
  description    String
  category       String   @default("General")
  content        String
  defaultContent String
  updatedAt      DateTime @updatedAt
  updatedBy      String?
}

/// Persisted ExecThread session cookies after email/password login.
model ExecThreadSession {
  id                     String    @id @default("default")
  cookies                Json
  lastSyncAt             DateTime?
  lastSyncError          String?
  catalogImportFrom      Int       @default(0)
  catalogImportTotalHits Int?
  catalogImportComplete  Boolean   @default(false)
  updatedAt              DateTime  @updatedAt
}

/// Persisted Big Biller session (cookies + token) after a successful MFA login.
model TopEchelonSession {
  id           String    @id @default("default")
  cookies      Json
  tokenPayload Json?
  lastSyncAt   DateTime?
  lastSyncError String?
  updatedAt    DateTime  @updatedAt
}

/// Recruiters who share jobs via Top Echelon Big Biller network.
model NetworkRecruiter {
  id          String       @id @default(cuid())
  externalId  String       @unique
  firstName   String?
  lastName    String?
  name        String?
  email       String?
  phone       String?
  agencyName  String?
  raw         Json
  syncedAt    DateTime     @default(now())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  jobs        NetworkJob[]

  @@index([name])
  @@index([agencyName])
}

/// Network-shared jobs imported from recruiter networks (Top Echelon, ExecThread, …).
model NetworkJob {
  id                  String            @id @default(cuid())
  source              NetworkJobSource  @default(TOPECHELON)
  externalId          String
  networkId           String?
  positionTitle       String
  companyName         String?
  city                String?
  state               String?
  location            String?
  minimumCompensation Int?
  maximumCompensation Int?
  fee                 String?
  feeType             String?
  jobType             String?
  remoteOption        String?
  description         String?
  comments            String?
  networkStatus       String?
  recruiterName       String?
  recruiterId         String?
  topEchelonUrl       String?
  sourceUrl           String?
  sharedAt            DateTime?
  raw                 Json
  syncedAt            DateTime          @default(now())
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  recruiterRecordId   String?
  recruiterRecord     NetworkRecruiter? @relation(fields: [recruiterRecordId], references: [id])

  @@unique([source, externalId])
  @@index([source])
  @@index([sharedAt])
  @@index([networkStatus])
  @@index([recruiterRecordId])
}

enum NetworkJobRequestType {
  INTRO
  SEND_PROFILE
}

enum NetworkJobRequestStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

/// Client requests for in-network roles — intro coordination or profile send (admin queue).
model NetworkJobRequest {
  id                   String                  @id @default(cuid())
  userId               String
  user                 User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobSource            NetworkJobSource
  jobExternalId        String
  requestType          NetworkJobRequestType
  status               NetworkJobRequestStatus @default(PENDING)
  jobTitle             String
  companyName          String?
  channelCode          String?
  recruiterName        String?
  clientNotes          String?                 @db.Text
  adminNotes           String?                 @db.Text
  handledByUserId      String?
  handledAt            DateTime?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  @@index([status, createdAt])
  @@index([userId, jobExternalId, requestType])
  @@index([jobSource, jobExternalId])
}

enum PlanCreditFeature {
  MATCH
  TAILOR
  COVER_LETTER
  SCOUT
  INSIDER
  READBACK
  STRATEGY
}

model DailyFeatureUsage {
  id        String            @id @default(cuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  day       String
  feature   PlanCreditFeature
  count     Int               @default(0)
  updatedAt DateTime          @updatedAt

  @@unique([userId, day, feature])
  @@index([userId])
}

model FeatureCreditBonus {
  id        String            @id @default(cuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  feature   PlanCreditFeature
  remaining Int               @default(0)
  updatedAt DateTime          @updatedAt

  @@unique([userId, feature])
  @@index([userId])
}

model ReferralEvent {
  id          String   @id @default(cuid())
  referrerId  String
  referrer    User     @relation("ReferrerEvents", fields: [referrerId], references: [id], onDelete: Cascade)
  refereeId   String   @unique
  referee     User     @relation("RefereeEvent", fields: [refereeId], references: [id], onDelete: Cascade)
  matchBonus  Int      @default(5)
  tailorBonus Int      @default(5)
  insiderBonus Int     @default(5)
  createdAt   DateTime @default(now())

  @@index([referrerId])
}

enum LinkedInShareStatus {
  PENDING
  APPROVED
  REJECTED
}

model LinkedInShareSubmission {
  id        String              @id @default(cuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  postUrl   String
  status    LinkedInShareStatus @default(PENDING)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([userId])
}

model ProTrialGrant {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  source    String
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

/// Global Hirebase job payload cache — keyed by Hirebase `_id` to avoid repeat fetches.
model JobListingCache {
  id          String   @id @default(cuid())
  hirebaseId  String   @unique
  payload     Json
  companyName String?
  fetchedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([fetchedAt])
}

/// Daily precomputed recommended jobs per user (cron + optional manual refresh).
model RecommendedJobSnapshot {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshotDate       String
  jobs               Json
  matchMode          String
  companyCount       Int      @default(0)
  trackedWithMatches Int      @default(0)
  jobCount           Int      @default(0)
  generatedAt        DateTime @default(now())
  manualRefresh      Boolean  @default(false)

  @@unique([userId, snapshotDate])
  @@index([userId])
  @@index([snapshotDate])
}

/// Email digest preferences for new 80+ recommended matches.
model UserDigestSettings {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyEmailEnabled Boolean   @default(true)
  watchlistEmailEnabled Boolean @default(true)
  pipelineEmailEnabled Boolean @default(true)
  lastDigestSentAt  DateTime?
  lastWatchlistSentAt DateTime?
  lastDigestJobIds  String[]  @default([])
  lastWatchlistJobIds String[] @default([])
  lastManualRefreshAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

/// Dedicated job-search inbox connected via Nylas (Gmail/Outlook).
model UserEmailGrant {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nylasGrantId String   @unique
  email        String?
  provider     String?
  connectedAt  DateTime @default(now())
  lastSyncAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([nylasGrantId])
}

/// Job-search email agent preferences (auto-enabled; user can opt out).
model UserJobAgentSettings {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  enabled          Boolean  @default(true)
  autoApplyUpdates Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

enum JobActivitySource {
  EMAIL
  CALENDAR
  KIMCHI_AGENT
}

enum JobActivitySignal {
  APPLICATION_RECEIVED
  INTERVIEW_INVITE
  REJECTION
  OFFER
  RECRUITER_OUTREACH
  FOLLOW_UP
  OTHER
}

enum JobActivityStatus {
  APPLIED
  PENDING_REVIEW
  DISMISSED
  SKIPPED
  FAILED
}

/// Log of email/calendar signals processed by the job-search agent.
model JobActivityLog {
  id             String            @id @default(cuid())
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId          String?
  job            Job?              @relation(fields: [jobId], references: [id], onDelete: SetNull)
  source         JobActivitySource
  signal         JobActivitySignal
  suggestedStage JobStage?
  appliedStage   JobStage?
  status         JobActivityStatus @default(PENDING_REVIEW)
  confidence     Float?
  title          String?
  snippet        String?
  companyGuess   String?
  roleGuess      String?
  nylasMessageId String?
  nylasEventId   String?
  interviewAt    DateTime?
  rawPayload     Json?
  createdAt      DateTime          @default(now())

  @@unique([userId, nylasMessageId])
  @@unique([userId, nylasEventId])
  @@index([userId, createdAt])
  @@index([userId, status])
}

enum InboxContactSource {
  EMAIL
  NYLAS
  MANUAL
}

enum InboxActivityKind {
  EMAIL
  MEETING
}

enum InboxActivityDirection {
  INBOUND
  OUTBOUND
}

enum InboxActivityCategory {
  NEWSLETTER
  AUTOMATED
  RECRUITER
  JOB_SEARCH
  PERSONAL
  UNKNOWN
}

/// CRM contact derived from email/calendar participants (cold contacts OK).
model InboxContact {
  id             String             @id @default(cuid())
  userId         String
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  email          String
  name           String?
  company        String?
  title          String?
  phone          String?
  linkedinUrl    String?
  notes          String?            @db.Text
  contacted      Boolean?
  nylasContactId String?
  source         InboxContactSource @default(EMAIL)
  status         String?
  statusUpdatedAt DateTime?
  lastActivityAt DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  activities InboxActivity[]
  jobLinks   JobInboxContact[]

  @@unique([userId, email])
  @@index([userId])
  @@index([userId, status])
  @@index([userId, lastActivityAt])
}

/// Optional link between a CRM contact and a pipeline job.
model JobInboxContact {
  id        String       @id @default(cuid())
  userId    String
  jobId     String
  contactId String
  role      String?
  createdAt DateTime     @default(now())

  job     Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  contact InboxContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([jobId, contactId])
  @@index([userId])
  @@index([contactId])
}

/// Rule-based activity log for all inbox mail and meetings (no AI on ingest).
model InboxActivity {
  id             String                 @id @default(cuid())
  userId         String
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind           InboxActivityKind
  direction      InboxActivityDirection
  category       InboxActivityCategory  @default(UNKNOWN)
  contactId      String?
  contact        InboxContact?          @relation(fields: [contactId], references: [id], onDelete: SetNull)
  jobId          String?
  job            Job?                   @relation(fields: [jobId], references: [id], onDelete: SetNull)
  nylasMessageId String?
  nylasEventId   String?
  nylasThreadId  String?
  subject        String?
  snippet        String?
  userTag        String?
  occurredAt     DateTime?
  rawPayload     Json?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@unique([userId, nylasMessageId])
  @@unique([userId, nylasEventId])
  @@index([userId, occurredAt])
  @@index([userId, contactId])
  @@index([userId, category])
}

/// Kimchi assistant conversation threads (chat + voice debrief blocks).
model AssistantThread {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   @default("New chat")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  AssistantMessage[]

  @@index([userId, updatedAt])
}

model AssistantMessage {
  id        String   @id @default(cuid())
  threadId  String
  thread    AssistantThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  kind      String   @default("text")
  role      String
  content   String   @db.Text
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([threadId, createdAt])
}

/// Reusable application Q&A pairs for job applications (user-managed bank).
model ApplicationQaEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question  String   @db.Text
  answer    String   @db.Text
  tags      String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, updatedAt])
}

enum ImportRunStatus {
  SUCCESS
  SOME_FAILURES
  FAILED
}

/// Persisted admin/client import runs for history and completion screens.
model ImportRun {
  id             String          @id @default(cuid())
  clientUserId   String
  clientUser     User            @relation("ClientImportRuns", fields: [clientUserId], references: [id], onDelete: Cascade)
  importedById   String
  importedBy     User            @relation("ImportedByImportRuns", fields: [importedById], references: [id], onDelete: Cascade)
  importType     String
  fileName       String?
  sourceKind     String
  status         ImportRunStatus
  createdCount   Int             @default(0)
  updatedCount   Int             @default(0)
  skippedCount   Int             @default(0)
  failedCount    Int             @default(0)
  resultSnapshot Json
  errorDetails   Json?
  createdAt      DateTime        @default(now())

  @@index([clientUserId, createdAt(sort: Desc)])
  @@index([importedById])
}

/// Kimchi-owned Nylas Agent Account (system mailbox).
model KimchiAgentAccount {
  id           String   @id @default(cuid())
  purpose      String   @unique
  email        String   @unique
  nylasGrantId String   @unique
  displayName  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
