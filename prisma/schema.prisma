generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatarUrl String?
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stripeCustomerId String? @unique

  referralCode         String?   @unique
  referredByUserId     String?
  referredBy           User?     @relation("UserReferrals", fields: [referredByUserId], references: [id], onDelete: SetNull)
  referrals            User[]    @relation("UserReferrals")
  onboardingCompletedAt DateTime?

  profile          Profile?
  jobs             Job[]
  trackedCompanies TrackedCompany[]
  subscription     Subscription?
  tailoredResumes  TailoredResume[]
  coachProfile     CoachProfile?
  aiUsageLogs      AiUsageLog[]
  monthlyUsage     MonthlyUsage[]
  dailyFeatureUsage DailyFeatureUsage[]
  featureCreditBonus FeatureCreditBonus[]
  assets           UserAsset[]
  referralsSent    ReferralEvent[] @relation("ReferrerEvents")
  referralReceived ReferralEvent?  @relation("RefereeEvent")
  linkedInShareSubmissions LinkedInShareSubmission[]
  proTrialGrants   ProTrialGrant[]
  recommendedSnapshots RecommendedJobSnapshot[]
  digestSettings       UserDigestSettings?

  @@index([referredByUserId])
}

enum UserRole {
  USER
  COACH
  RECRUITER
  ADMIN
}

model Subscription {
  id                     String             @id @default(cuid())
  userId                 String             @unique
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  stripeSubscriptionId   String             @unique
  stripePriceId          String
  stripeCurrentPeriodEnd DateTime
  status                 SubscriptionStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  UNPAID
  TRIALING
  INCOMPLETE
  INCOMPLETE_EXPIRED
  PAUSED
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  resumeUrl   String?
  resumeText  String?
  parsedData  Json?
  linkedinUrl String?
  headline    String?
  summary     String?
  targetRoles      String[]
  targetSalary     String?
  employmentStatus String?
  currentSalary    String?
  priorities       String[]
  careerMotivation String?
  jobTimeline      String?
  attribution      String?

  readbackData       Json?
  readbackUpdatedAt  DateTime?

  linkedInDraft              Json?
  linkedInDraftUpdatedAt     DateTime?
  linkedInDraftSourceAssetId String?
  linkedInDraftAnalysis      Json?
  linkedInDraftAnalysisUpdatedAt DateTime?

  roleAnalyses    Json?
  skillGoals      Json?
  upskillProgress Json?
  targetRoleSettings Json?

  targetMarket           String?
  relocationOpenness     String?
  workAuthorization      String?
  securityClearance      String?
  searchDuration         String?
  positioningStatement   String?  @db.Text

  strategyData             Json?
  strategyUpdatedAt        DateTime?
  strategySourceSnapshot   Json?
  strategyIntakeNotes      String?  @db.Text
  strategyHistory          Json?
  strategyGenerationStatus      String?
  strategyGenerationStartedAt   DateTime?
  strategyGenerationCompletedAt DateTime?
  strategyGenerationError       String?  @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum AssetType {
  RESUME
  COVER_LETTER
  JOB_SEARCH_STRATEGY
  OTHER
}

model UserAsset {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      AssetType
  name      String
  url       String
  isPrimary Boolean   @default(false)

  resumeText         String?
  parsedData         Json?
  analysisData       Json?
  analysisUpdatedAt  DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
}

model Job {
  id      String   @id @default(cuid())
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  url          String?
  company      String
  role         String
  stage        JobStage @default(SAVED)
  notes        String?

  userNotes          String?
  companyLinkedinUrl String?

  resumeUrl    String?
  coverLetter  String?
  fitAnalysis  String?

  appliedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tailoredResume TailoredResume?
}

model TailoredResume {
  id        String   @id @default(cuid())
  jobId     String   @unique
  userId    String
  sections  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CoachProfile {
  id             String      @id @default(cuid())
  userId         String?     @unique
  user           User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  airtableId     String?     @unique

  displayName    String
  email          String?     @unique
  headline       String?
  bio            String?
  currentRole    String?
  currentCompany String?
  location       String?
  linkedinUrl    String?
  lelandUrl      String?
  photoUrl       String?

  firms          String[]
  schools        String[]
  specialties    String[]
  industries     String[]

  hourlyRate     Int?
  category       String?
  featured       Boolean     @default(false)
  status         CoachStatus @default(ACTIVE)

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

enum CoachStatus {
  ACTIVE
  PENDING
  INACTIVE
}

enum JobStage {
  SAVED
  APPLYING
  APPLIED
  SCREENING
  INTERVIEWING
  OFFER
  REJECTED
  WITHDRAWN
}

enum AiFeature {
  COVER_LETTER
  FIT_ANALYSIS
  RESUME_BULLETS
  RESUME_PARSE
  JOB_PARSE
  CHAT
  RESUME_TAILOR
}

model CompanyIntel {
  id                   String    @id @default(cuid())
  name                 String
  slug                 String    @unique
  website              String?
  careersUrl           String?
  jobsCache            Json?
  lastJobsFetchedAt    DateTime?
  enrichmentCache      Json?
  enrichmentFetchedAt  DateTime?

  trackedCompanies TrackedCompany[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TrackedCompany {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyIntelId       String?
  companyIntel         CompanyIntel? @relation(fields: [companyIntelId], references: [id], onDelete: SetNull)

  name              String
  website           String?
  notes             String?
  type              String?
  hqLocation        String?
  priority          String?
  cultureMission    String?
  candidateEdge     String?
  targetRoles       String?
  careersUrl           String?
  jobsCache            Json?
  lastJobsFetchedAt    DateTime?
  enrichmentCache      Json?
  enrichmentFetchedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([companyIntelId])
}

model AiUsageLog {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  feature   AiFeature
  model     String
  tokensIn  Int        @default(0)
  tokensOut Int        @default(0)
  costUsd   Float      @default(0)
  createdAt DateTime   @default(now())

  @@index([userId])
  @@index([createdAt])
}

model MonthlyUsage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month     String
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([userId, month])
  @@index([userId])
}

model PromptConfig {
  id             String   @id @default(cuid())
  key            String   @unique
  label          String
  description    String
  category       String   @default("General")
  content        String
  defaultContent String
  updatedAt      DateTime @updatedAt
  updatedBy      String?
}

/// Persisted Big Biller session (cookies + token) after a successful MFA login.
model TopEchelonSession {
  id           String    @id @default("default")
  cookies      Json
  tokenPayload Json?
  lastSyncAt   DateTime?
  lastSyncError String?
  updatedAt    DateTime  @updatedAt
}

/// Recruiters who share jobs via Top Echelon Big Biller network.
model NetworkRecruiter {
  id          String       @id @default(cuid())
  externalId  String       @unique
  firstName   String?
  lastName    String?
  name        String?
  email       String?
  phone       String?
  agencyName  String?
  raw         Json
  syncedAt    DateTime     @default(now())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  jobs        NetworkJob[]

  @@index([name])
  @@index([agencyName])
}

/// Network-shared jobs imported from Top Echelon Big Biller.
model NetworkJob {
  id                  String            @id @default(cuid())
  externalId          String            @unique
  networkId           String?
  positionTitle       String
  companyName         String?
  city                String?
  state               String?
  location            String?
  minimumCompensation Int?
  maximumCompensation Int?
  fee                 String?
  feeType             String?
  jobType             String?
  remoteOption        String?
  description         String?
  comments            String?
  networkStatus       String?
  recruiterName       String?
  recruiterId         String?
  topEchelonUrl       String?
  sharedAt            DateTime?
  raw                 Json
  syncedAt            DateTime          @default(now())
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  recruiterRecordId   String?
  recruiterRecord     NetworkRecruiter? @relation(fields: [recruiterRecordId], references: [id])

  @@index([sharedAt])
  @@index([networkStatus])
  @@index([recruiterRecordId])
}

enum PlanCreditFeature {
  MATCH
  TAILOR
  COVER_LETTER
  SCOUT
  INSIDER
  READBACK
  STRATEGY
}

model DailyFeatureUsage {
  id        String            @id @default(cuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  day       String
  feature   PlanCreditFeature
  count     Int               @default(0)
  updatedAt DateTime          @updatedAt

  @@unique([userId, day, feature])
  @@index([userId])
}

model FeatureCreditBonus {
  id        String            @id @default(cuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  feature   PlanCreditFeature
  remaining Int               @default(0)
  updatedAt DateTime          @updatedAt

  @@unique([userId, feature])
  @@index([userId])
}

model ReferralEvent {
  id          String   @id @default(cuid())
  referrerId  String
  referrer    User     @relation("ReferrerEvents", fields: [referrerId], references: [id], onDelete: Cascade)
  refereeId   String   @unique
  referee     User     @relation("RefereeEvent", fields: [refereeId], references: [id], onDelete: Cascade)
  matchBonus  Int      @default(5)
  tailorBonus Int      @default(5)
  insiderBonus Int     @default(5)
  createdAt   DateTime @default(now())

  @@index([referrerId])
}

enum LinkedInShareStatus {
  PENDING
  APPROVED
  REJECTED
}

model LinkedInShareSubmission {
  id        String              @id @default(cuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  postUrl   String
  status    LinkedInShareStatus @default(PENDING)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([userId])
}

model ProTrialGrant {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  source    String
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

/// Global Hirebase job payload cache — keyed by Hirebase `_id` to avoid repeat fetches.
model JobListingCache {
  id          String   @id @default(cuid())
  hirebaseId  String   @unique
  payload     Json
  companyName String?
  fetchedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([fetchedAt])
}

/// Daily precomputed recommended jobs per user (cron + optional manual refresh).
model RecommendedJobSnapshot {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshotDate       String
  jobs               Json
  matchMode          String
  companyCount       Int      @default(0)
  trackedWithMatches Int      @default(0)
  jobCount           Int      @default(0)
  generatedAt        DateTime @default(now())
  manualRefresh      Boolean  @default(false)

  @@unique([userId, snapshotDate])
  @@index([userId])
  @@index([snapshotDate])
}

/// Email digest preferences for new 80+ recommended matches.
model UserDigestSettings {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyEmailEnabled Boolean   @default(true)
  lastDigestSentAt  DateTime?
  lastDigestJobIds  String[]  @default([])
  lastManualRefreshAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}
